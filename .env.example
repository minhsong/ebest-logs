# ebest-activity-log — Activity Log Service
PORT=3010
NODE_ENV=development
API_PREFIX=api
APP_NAME=ebest-activity-log

MONGODB_URI=mongodb://127.0.0.1:27017/ebest_activity_log
MONGODB_ENABLED=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=ebest-activity-log:
REDIS_ENABLED=true

# Stream key — phải khớp CRM ACTIVITY_LOG_REDIS_STREAM
ACTIVITY_LOG_REDIS_STREAM=ebest-crm:activity:events
ACTIVITY_LOG_CONSUMER_GROUP=activity-log-workers
ACTIVITY_LOG_CONSUMER_NAME=worker-1
ACTIVITY_LOG_STREAM_MAXLEN=100000
ACTIVITY_LOG_RETENTION_DAYS=365
ACTIVITY_LOG_INGEST_MAX_RETRIES=3

# Ingest: redis (prod) | file (dev — tail JSONL từ CRM)
ACTIVITY_LOG_INGEST_MODE=redis
# Dev file mode — khớp CRM ACTIVITY_LOG_FILE_PATH:
# ACTIVITY_LOG_INGEST_MODE=file
# ACTIVITY_LOG_FILE_INGEST_PATH=../ebest-crm-api/logs/activity-events.jsonl

# Khớp CRM ACTIVITY_LOG_INTERNAL_API_KEY (ưu tiên INTERNAL_API_KEY, fallback ACTIVITY_LOG_INTERNAL_API_KEY)
INTERNAL_API_KEY=change-me-activity-log-internal
