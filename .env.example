# ebest-logs — unified Activity + Error log service
PORT=3010
NODE_ENV=development
API_PREFIX=api
APP_NAME=ebest-logs

MONGODB_URI=mongodb://127.0.0.1:27017/ebest_logs
MONGODB_ENABLED=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=ebest-logs:
REDIS_ENABLED=true

# Khớp LOGS_INTERNAL_API_KEY trên ebest-crm-api
LOGS_INTERNAL_API_KEY=change-me-logs-internal

# --- Activity log ingest ---
ACTIVITY_LOG_REDIS_STREAM=ebest-crm:activity:events
ACTIVITY_LOG_CONSUMER_GROUP=activity-log-workers
ACTIVITY_LOG_CONSUMER_NAME=worker-1
ACTIVITY_LOG_STREAM_MAXLEN=100000
ACTIVITY_LOG_RETENTION_DAYS=365
ACTIVITY_LOG_INGEST_MAX_RETRIES=3
ACTIVITY_LOG_INGEST_MODE=redis

# --- Error log ingest ---
ERROR_LOG_REDIS_STREAM=ebest:system:errors
ERROR_LOG_CONSUMER_GROUP=error-log-workers
ERROR_LOG_CONSUMER_NAME=error-worker-1
ERROR_LOG_STREAM_MAXLEN=100000
ERROR_LOG_RETENTION_DAYS=90
ERROR_LOG_INGEST_MAX_RETRIES=3
ERROR_LOG_INGEST_MODE=redis

# --- Query cache (Redis) ---
LOGS_QUERY_CACHE_ENABLED=true
LOGS_QUERY_CACHE_TTL_SEC=20
LOGS_QUERY_CACHE_SKIP_Q=true

# --- Consumer tuning ---
ACTIVITY_LOG_CONSUMER_BATCH_SIZE=20
ACTIVITY_LOG_CONSUMER_BLOCK_MS=5000
ERROR_LOG_CONSUMER_BATCH_SIZE=20
ERROR_LOG_CONSUMER_BLOCK_MS=5000
