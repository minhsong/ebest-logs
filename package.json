{
  "name": "ebest-logs",
  "version": "0.2.0",
  "private": true,
  "description": "Unified log service — business activity + system errors (Redis Stream, MongoDB, internal query API)",
  "license": "MIT",
  "scripts": {
    "prebuild": "npm run build:types && rimraf dist",
    "build:types": "npm run build --prefix ../ebest-crm-api/packages/crm-api-types && npm run build --prefix ./packages/activity-log-types && npm run build --prefix ./packages/error-log-types",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "@ebest/crm-api-types": "file:../ebest-crm-api/packages/crm-api-types",
    "@ebest/activity-log-types": "file:./packages/activity-log-types",
    "@ebest/error-log-types": "file:./packages/error-log-types",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "mongoose": "^8.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18.0 || >=20.9.0"
  }
}
